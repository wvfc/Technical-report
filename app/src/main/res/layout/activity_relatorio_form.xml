<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/backgroundLight">

    <LinearLayout
        android:orientation="vertical"
        android:padding="16dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <com.google.android.material.card.MaterialCardView
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardElevation="2dp"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="@color/white">

            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp">

                <!-- Cliente -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Cliente *"
                    android:textColor="@color/hintGray"
                    android:textSize="13sp"
                    android:layout_marginBottom="4dp" />

                <Spinner
                    android:id="@+id/spCliente"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_spinner"
                    android:popupBackground="@color/white"
                    android:layout_marginBottom="16dp" />

                <!-- Máquina vinculada (opcional) -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Máquina cadastrada (opcional)"
                    android:textColor="@color/hintGray"
                    android:textSize="13sp"
                    android:layout_marginBottom="4dp" />

                <Spinner
                    android:id="@+id/spMaquina"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_spinner"
                    android:popupBackground="@color/white"
                    android:layout_marginBottom="16dp" />

                <!-- Datas -->
                <EditText
                    android:id="@+id/edDataEntrada"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Data e hora de entrada *"
                    android:focusable="false"
                    android:textColor="@color/textPrimary"
                    android:textColorHint="@color/hintGray"
                    android:layout_marginBottom="8dp" />

                <EditText
                    android:id="@+id/edDataSaida"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Data e hora de saída *"
                    android:focusable="false"
                    android:textColor="@color/textPrimary"
                    android:textColorHint="@color/hintGray"
                    android:layout_marginBottom="8dp" />

                <!-- Modelo da máquina -->
                <EditText
                    android:id="@+id/edModeloMaquina"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Modelo da máquina *"
                    android:textColor="@color/textPrimary"
                    android:textColorHint="@color/hintGray"
                    android:layout_marginBottom="8dp" />

                <!-- Tipo de manutenção -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Tipo de manutenção *"
                    android:textColor="@color/hintGray"
                    android:textSize="13sp"
                    android:layout_marginBottom="4dp" />

                <Spinner
                    android:id="@+id/spTipoManutencao"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_spinner"
                    android:popupBackground="@color/white"
                    android:layout_marginBottom="16dp" />

                <!-- Ocorrência -->
                <EditText
                    android:id="@+id/edOcorrencia"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Ocorrência *"
                    android:inputType="textMultiLine"
                    android:minLines="3"
                    android:gravity="top"
                    android:textColor="@color/textPrimary"
                    android:textColorHint="@color/hintGray"
                    android:layout_marginBottom="8dp" />

                <!-- Solução proposta -->
                <EditText
                    android:id="@+id/edSolucao"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Solução proposta *"
                    android:inputType="textMultiLine"
                    android:minLines="3"
                    android:gravity="top"
                    android:textColor="@color/textPrimary"
                    android:textColorHint="@color/hintGray"
                    android:layout_marginBottom="8dp" />

                <!-- Lista de peças -->
                <EditText
                    android:id="@+id/edPecas"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Lista de peças (um item por linha)"
                    android:inputType="textMultiLine"
                    android:minLines="3"
                    android:gravity="top"
                    android:textColor="@color/textPrimary"
                    android:textColorHint="@color/hintGray"
                    android:layout_marginBottom="16dp" />

                <!-- Botões -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSelecionarImagens"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Selecionar imagens"
                    app:strokeColor="@color/colorPrimary"
                    android:textColor="@color/colorPrimary"
                    android:layout_marginBottom="12dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSalvarRelatorio"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Salvar e gerar PDF"
                    android:backgroundTint="@color/colorPrimary"
                    android:textColor="@color/white"
                    android:layout_marginBottom="8dp" />

                <!-- Progress during save -->
                <ProgressBar
                    android:id="@+id/progressSalvar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:visibility="gone"
                    android:layout_marginBottom="8dp" />

                <Button
                    android:id="@+id/btnVoltar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Voltar"
                    android:backgroundTint="@color/buttonSecondary"
                    android:textColor="@color/white" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
