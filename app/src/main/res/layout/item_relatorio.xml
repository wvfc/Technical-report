<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="4dp"
    app:cardElevation="3dp"
    app:cardCornerRadius="10dp"
    app:cardBackgroundColor="@color/white"
    app:strokeWidth="1dp"
    app:strokeColor="@color/divider">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Faixa de cor por tipo (indicador lateral) -->
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Barra lateral colorida -->
            <View
                android:id="@+id/barraLateral"
                android:layout_width="4dp"
                android:layout_height="match_parent"
                android:background="@color/colorPrimary" />

            <LinearLayout
                android:orientation="vertical"
                android:padding="14dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <!-- Linha 1: Equipamento + Chip tipo -->
                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="4dp">

                    <TextView
                        android:id="@+id/tvTituloRelatorio"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Equipamento"
                        android:textStyle="bold"
                        android:textSize="15sp"
                        android:textColor="@color/textPrimary"
                        android:singleLine="true"
                        android:ellipsize="end"
                        android:layout_marginEnd="8dp" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipTipo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Geral"
                        android:textSize="10sp"
                        android:textColor="@color/colorPrimary"
                        app:chipBackgroundColor="@color/colorPrimaryContainer"
                        app:chipMinHeight="24dp"
                        android:clickable="false"
                        android:focusable="false" />
                </LinearLayout>

                <!-- Linha 2: Manutenção • Data -->
                <TextView
                    android:id="@+id/tvLinha2Relatorio"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Tipo de manutenção • Data"
                    android:textSize="12sp"
                    android:textColor="@color/textSecondary"
                    android:layout_marginBottom="2dp" />

                <!-- Linha 3: Cliente -->
                <TextView
                    android:id="@+id/tvLinha3Relatorio"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Cliente"
                    android:textSize="12sp"
                    android:textColor="@color/hintGray" />

                <!-- Divisor -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="8dp" />

                <!-- Linha de ação -->
                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="end">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnWhatsapp"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Compartilhar"
                        android:textSize="12sp"
                        android:textColor="@color/colorPrimary" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
