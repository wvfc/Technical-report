<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/backgroundLight">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Search bar -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilBusca"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="12dp"
            app:startIconDrawable="@android:drawable/ic_menu_search"
            app:startIconTint="@color/colorPrimary"
            android:hint="Buscar cliente...">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etBusca"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:imeOptions="actionSearch"
                android:maxLines="1" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Loading -->
        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:visibility="gone" />

        <!-- Empty state -->
        <TextView
            android:id="@+id/tvVazio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nenhum cliente encontrado.\nToque em + para adicionar."
            android:gravity="center"
            android:padding="32dp"
            android:textColor="@color/hintGray"
            android:visibility="gone" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvClientes"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:paddingBottom="80dp"
            android:clipToPadding="false" />
    </LinearLayout>

    <!-- FABs stacked -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:orientation="vertical"
        android:gravity="end">

        <!-- Import CSV/XLSX -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabImportarClientes"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:contentDescription="Importar clientes"
            android:src="@android:drawable/ic_menu_upload"
            app:backgroundTint="@color/colorAccent"
            app:tint="@color/white"
            app:fabSize="mini" />

        <!-- New client -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabNovoCliente"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:contentDescription="Novo cliente"
            android:src="@drawable/ic_fab_add"
            app:backgroundTint="@color/colorPrimary"
            app:tint="@color/white" />

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
